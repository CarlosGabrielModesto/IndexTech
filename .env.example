# ============================================================
#  Hygeia Digital — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha os valores reais.
#  NUNCA commite o .env com credenciais reais!
# ============================================================

# --- Notificador ---
# Opções: console | twilio | whatsapp
NOTIFIER=console

# --- Twilio (WhatsApp Sandbox ou número aprovado) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+5514900000000
TWILIO_CONTENT_SID=          # Opcional: SID do template no Twilio Console

# --- Meta Cloud API (alternativa ao Twilio) ---
WABA_TOKEN=
WABA_PHONE_ID=

# --- Banco de dados ---
# SQLite (padrão, ideal para desenvolvimento e hackathon)
DATABASE_URL=sqlite:///./hygeia.db
# PostgreSQL (produção):
# DATABASE_URL=postgresql+psycopg://usuario:senha@host:5432/hygeia

# --- Servidor ---
HOST=0.0.0.0
PORT=8000

# --- Webhook (necessário para receber respostas via WhatsApp) ---
BASE_URL=https://seu-dominio.ngrok.io